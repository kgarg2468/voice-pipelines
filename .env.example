# Copy to .env and fill in. companybrain.py auto-loads ./.env (no python-dotenv needed).

# ── RocketRide local engine (self-hosted OSS mode: any non-empty key works) ──
ROCKETRIDE_URI=ws://localhost:5565
ROCKETRIDE_APIKEY=MYAPIKEY

# ── OpenAI key the deep-agent LLM nodes use (resolved client-side at run time) ──
ROCKETRIDE_OPENAI_KEY=sk-...

# ── GitHub repo the brain reads issues/PRs from (seeded by ./seed_repo.sh) ──
ROCKETRIDE_GITHUB_REPO=kgarg2468/company-brain-demo

# ── Neo4j conflict graph for the planner (matches the `docker run` in the README) ──
COMPANYBRAIN_NEO4J_URI=neo4j://localhost:7687
COMPANYBRAIN_NEO4J_USER=neo4j
COMPANYBRAIN_NEO4J_PASSWORD=companybrain
